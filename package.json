{
  "scripts": {
    "start": "npm-run-all --parallel eleventy browsersync",
    "eleventy": "eleventy --watch",
    "debug": "set DEBUG=* & eleventy",
    "build": "cross-env NODE_ENV=production eleventy",
    "browsersync": "browser-sync start --server _site --files _site --port 8080 --no-notify --no-open",
    "watch": "sass --watch src/static/styles/styles.scss:src/static/styles/styles.css",
    "sass:build": "sass src/static/styles/styles.scss:src/static/styles/styles.css --style=compressed"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^3.1.3",
    "alpinejs": "^3.7.1",
    "browser-sync": "^2.27.7",
    "cross-env": "^7.0.3",
    "html-minifier": "^4.0.0",
    "js-yaml": "^4.1.0",
    "luxon": "^2.3.0",
    "netlify-plugin-cache": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "prismjs": "^1.26.0",
    "sass": "^1.99.0"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.1",
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0"
  },
  "name": "starter-template",
  "description": "Collection of UI utility classes, components, combos, sections, and partials. To get started pick what you need from the library and then be sure to delete the following:",
  "version": "1.0.0",
  "main": ".eleventy.js",
